    <worksheet name='Flags'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontname='Tableau Medium'>&lt;Sheet Name&gt;</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#666666' fontname='Benton Sans Book' fontsize='11'>Active risk indicators for this seller</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='at_risk_profiles_final+' name='federated.06mgibo0zdgdib1bhxrjp1fyqgp5' />
          </datasources>
          <datasource-dependencies datasource='federated.06mgibo0zdgdib1bhxrjp1fyqgp5'>
            <column caption='Flags Display' datatype='string' name='[Calculation_256986670297841672]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Active Flags Display&#13;&#10;IF [extreme_late_flag] = 1 &#13;&#10;THEN &quot;⚑  Extreme Late Orders&quot; + CHAR(10)&#13;&#10;ELSE &quot;&quot; END&#13;&#10;+&#13;&#10;IF [compound_failure] = 1 &#13;&#10;THEN &quot;⚑  Compound Failure&quot; + CHAR(10)&#13;&#10;ELSE &quot;&quot; END&#13;&#10;+&#13;&#10;IF [delivery_comms_compound] = 1 &#13;&#10;THEN &quot;⚑  Delivery + Comms Failure&quot; + CHAR(10)&#13;&#10;ELSE &quot;&quot; END&#13;&#10;+&#13;&#10;IF [flag_return_refund] = 1 &#13;&#10;THEN &quot;⚑  Return / Refund Raised&quot; + CHAR(10)&#13;&#10;ELSE &quot;&quot; END&#13;&#10;+&#13;&#10;IF [low_review_coverage] = 1 &#13;&#10;THEN &quot;(!)  Low Review Coverage (&lt;3 Categorised rev) — Profile Directional&quot;&#13;&#10;ELSE &quot;&quot; END&#13;&#10;+&#13;&#10;IF [extreme_late_flag] = 0 &#13;&#10;    AND [compound_failure] = 0 &#13;&#10;    AND [delivery_comms_compound] = 0&#13;&#10;    AND [flag_return_refund] = 0&#13;&#10;    AND [low_review_coverage] = 0&#13;&#10;THEN &quot;✓  No Additional Flags&quot;&#13;&#10;ELSE &quot;&quot;&#13;&#10;END' />
            </column>
            <column aggregation='Sum' caption='Compound Failure' datatype='integer' name='[compound_failure]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column caption='Delivery Comms Compound' datatype='integer' name='[delivery_comms_compound]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Extreme Late Flag' datatype='integer' name='[extreme_late_flag]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column caption='Flag Return Refund' datatype='integer' name='[flag_return_refund]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Low Review Coverage' datatype='integer' name='[low_review_coverage]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column-instance column='[Calculation_256986670297841672]' derivation='None' name='[none:Calculation_256986670297841672:nk]' pivot='key' type='nominal' />
            <column-instance column='[seller_id]' derivation='None' name='[none:seller_id:nk]' pivot='key' type='nominal' />
            <column caption='Seller Id' datatype='string' name='[seller_id]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.06mgibo0zdgdib1bhxrjp1fyqgp5].[Action (Seller Id)]'>
            <groupfilter function='member' level='[seller_id]' member='&quot;54965bbe3e4f07ae045b90b0b8541f52&quot;' user:ui-action-filter='[Action2_EAEF16F3F6174115808CA192166001D3]' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
