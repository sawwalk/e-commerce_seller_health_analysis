      <table>
        <view>
          <datasources>
            <datasource caption='at_risk_profiles_final+' name='federated.06mgibo0zdgdib1bhxrjp1fyqgp5' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='all sellers' caption='Active Sellers' datatype='boolean' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='false'>
              <calculation class='tableau' formula='false' />
              <aliases>
                <alias key='false' value='all sellers' />
                <alias key='true' value='Active sellers: at least one order placed between 2018-04-17 and 2018-10-17 (the final 6 months of the dataset).' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.06mgibo0zdgdib1bhxrjp1fyqgp5'>
            <column caption='Active seller filter' datatype='boolean' name='[Calculation_256986670004449281]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Boolean parameter version&#13;&#10;IF [Parameters].[Parameter 1] = TRUE&#13;&#10;THEN [orders_last_6_months (seller_health_scores.csv)] &gt;= 1&#13;&#10;ELSE TRUE&#13;&#10;END' />
            </column>
