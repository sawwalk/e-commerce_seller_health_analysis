    <worksheet name='Recommendations'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Tableau Medium'>Recommended Intervention</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='at_risk_profiles_final+' name='federated.06mgibo0zdgdib1bhxrjp1fyqgp5' />
          </datasources>
          <datasource-dependencies datasource='federated.06mgibo0zdgdib1bhxrjp1fyqgp5'>
            <column caption='Recommendations' datatype='string' name='[Calculation_256986670303473673]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Recommendation Text — v2&#13;&#10;CASE [intervention_priority]&#13;&#10;WHEN &apos;1 - Immediate (Delivery+Comms)&apos; THEN&#13;&#10;    &quot;PRIORITY 1 — IMMEDIATE ACTION&quot; + CHAR(10) +&#13;&#10;    &quot;This seller is flagged for a compound delivery + communication &quot; +&#13;&#10;    &quot;failure pattern. &quot; +&#13;&#10;    IF CONTAINS([dominant_category], &apos;Product&apos;) OR CONTAINS([dominant_category], &apos;Wrong Product&apos;) THEN&#13;&#10;        &quot;However, their largest driver of dissatisfaction is &quot; +&#13;&#10;        [dominant_category] + &quot;, — prioritize communication and product outreach, conduct logistics review according to complaint profile.&quot;&#13;&#10;    ELSEIF CONTAINS([dominant_category], &apos;Communication&apos;) THEN&#13;&#10;        &quot;In addition, a large proportion of dissatisfaction is driven by communication failure. &quot; + &#13;&#10;        &quot;Focus on communication-first outreach with delivery complaints as a secondary factor.&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;Delivery performance is also their dominant complaint driver, &quot; +&#13;&#10;        &quot;confirming logistics as the primary lever here.&quot;&#13;&#10;    END +&#13;&#10;    CHAR(10) + CHAR(10) +&#13;&#10;    &quot;Recommended actions:&quot; + CHAR(10) +&#13;&#10;    IF CONTAINS([dominant_category], &apos;Product&apos;) OR CONTAINS([dominant_category], &apos;Wrong Product&apos;) THEN&#13;&#10;        &quot;● Ask whether this seller has a documented pre-shipment QC process &quot; +&#13;&#10;        &quot;(listing-to-product accuracy check, defect inspection) — help them &quot; +&#13;&#10;        &quot;establish one if none exists&quot; + CHAR(10) +&#13;&#10;        &quot;● Escalate delivery-related complaints to logistics review in parallel&quot; + CHAR(10) +&#13;&#10;        &quot;● Ask whether a standardized customer communication framework exists &quot; +&#13;&#10;        &quot;(proactive shipment-status updates, defined response-time targets) — &quot; +&#13;&#10;        &quot;help establish one if not&quot; + CHAR(10) +&#13;&#10;        &quot;● Set 30-day checkpoint against both product-accuracy and response-time metrics&quot;&#13;&#10;    ELSEIF CONTAINS([dominant_category], &apos;Communication&apos;) THEN&#13;&#10;        &quot;● Ask whether a standardized customer communication framework exists &quot; +&#13;&#10;        &quot;today (proactive shipment-status updates, defined response-time &quot; +&#13;&#10;        &quot;targets) — help establish one if not&quot; + CHAR(10) +&#13;&#10;        &quot;● Escalate delivery-related complaints to logistics review in parallel&quot; + CHAR(10) +&#13;&#10;        &quot;● Audit current response-time SLA for this seller&apos;s support channel&quot; + CHAR(10) +&#13;&#10;        &quot;● Set 30-day review checkpoint&quot;&#13;&#10;    ELSE&#13;&#10;        &quot;● Escalate to logistics review immediately&quot; + CHAR(10) +&#13;&#10;        &quot;● Ask whether a standardized customer communication framework exists &quot; +&#13;&#10;        &quot;(proactive shipment-status updates, defined response-time targets) — &quot; +&#13;&#10;        &quot;help establish one if not&quot; + CHAR(10) +&#13;&#10;        &quot;● Investigate carrier assignment for this seller&apos;s region&quot; + CHAR(10) +&#13;&#10;        &quot;● Set 30-day review checkpoint&quot;&#13;&#10;    END&#13;&#10;&#13;&#10;WHEN &apos;2 - Logistics Intervention&apos;&#13;&#10;THEN&#13;&#10;&quot;PRIORITY 2 — LOGISTICS INTERVENTION&quot; + CHAR(10) +&#13;&#10;&quot;This seller has significant delivery performance issues &quot; +&#13;&#10;&quot;without compound communication failure.&quot; +&#13;&#10;CHAR(10) + CHAR(10) +&#13;&#10;&quot;Recommended actions:&quot; + CHAR(10) +&#13;&#10;&quot;● Review carrier assignment and delivery time patterns&quot; + CHAR(10) +&#13;&#10;&quot;● Compare delivery performance against sellers in same region&quot; + CHAR(10) +&#13;&#10;&quot;● Advise seller on realistic shipping limit dates&quot; + CHAR(10) +&#13;&#10;&quot;● Set 60-day review checkpoint&quot;&#13;&#10;&#13;&#10;WHEN &apos;3 - Product Intervention&apos;&#13;&#10;THEN&#13;&#10;    &quot;PRIORITY 3 — PRODUCT INTERVENTION&quot; + CHAR(10) +&#13;&#10;    &quot;This seller&apos;s failure mode is product-related rather than &quot; +&#13;&#10;    &quot;logistics.&quot; +&#13;&#10;    CHAR(10) + CHAR(10) +&#13;&#10;    &quot;Recommended actions:&quot; + CHAR(10) +&#13;&#10;    &quot;● Ask whether this seller has a documented pre-shipment QC process &quot; +&#13;&#10;    &quot;(listing-to-product accuracy check, defect inspection) — help them &quot; +&#13;&#10;    &quot;establish one if none exists&quot; + CHAR(10) +&#13;&#10;    &quot;● Review this seller&apos;s Wrong Product / Product Quality complaints &quot; +&#13;&#10;    &quot;(see Review Profile panel) to confirm whether the root cause is &quot; +&#13;&#10;    &quot;listing accuracy, sourcing, or physical defects&quot; + CHAR(10) +&#13;&#10;    IF [packaging_count] &gt; 0 THEN&#13;&#10;        &quot;● Poor Packaging complaints are also present for this seller — &quot; +&#13;&#10;        &quot;advise on packaging standards alongside the product-accuracy work&quot;&#13;&#10;    ELSE &#13;&#10;        &quot;● No Poor Packaging complaints for this seller — packaging is not &quot; +&#13;&#10;        &quot;the lever here, focus outreach on product accuracy&quot;&#13;&#10;    END + CHAR(10) +&#13;&#10;    &quot;● Set 60-day checkpoint against product-accuracy metrics (1-star rate, &quot; +&#13;&#10;    &quot;Wrong Product / Product Quality complaint volume)&quot;&#13;&#10;&#13;&#10;WHEN &apos;4 - Review Directly&apos;&#13;&#10;THEN&#13;&#10;&quot;PRIORITY 4 — REVIEW DIRECTLY&quot; + CHAR(10) +&#13;&#10;&quot;This seller has low complaint volume and limited categorised &quot; +&#13;&#10;&quot;review coverage. Profile is directional only.&quot; +&#13;&#10;CHAR(10) + CHAR(10) +&#13;&#10;&quot;Recommended actions:&quot; + CHAR(10) +&#13;&#10;&quot;● Review raw negative reviews manually before outreach&quot; + CHAR(10) +&#13;&#10;&quot;● Monitor order volume and review score trend&quot; + CHAR(10) +&#13;&#10;&quot;● No immediate escalation required&quot; + CHAR(10) +&#13;&#10;&quot;● Reassess at next scoring cycle&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Dominant Category' datatype='string' name='[dominant_category]' role='dimension' type='nominal' />
            <column caption='Intervention Priority' datatype='string' name='[intervention_priority]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_256986670303473673]' derivation='None' name='[none:Calculation_256986670303473673:nk]' pivot='key' type='nominal' />
            <column-instance column='[seller_id]' derivation='None' name='[none:seller_id:nk]' pivot='key' type='nominal' />
            <column caption='Packaging Count' datatype='integer' name='[packaging_count]' role='measure' type='quantitative' />
            <column caption='Seller Id' datatype='string' name='[seller_id]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.06mgibo0zdgdib1bhxrjp1fyqgp5].[Action (Seller Id)]'>
            <groupfilter function='member' level='[seller_id]' member='&quot;54965bbe3e4f07ae045b90b0b8541f52&quot;' user:ui-action-filter='[Action2_EAEF16F3F6174115808CA192166001D3]' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.06mgibo0zdgdib1bhxrjp1fyqgp5].[Action (Seller Id)]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <lod column='[federated.06mgibo0zdgdib1bhxrjp1fyqgp5].[none:seller_id:nk]' />
              <text column='[federated.06mgibo0zdgdib1bhxrjp1fyqgp5].[none:Calculation_256986670303473673:nk]' />
            </encodings>
            <customized-tooltip>
              <formatted-text>
                <run fontcolor='#757575'>Seller Id:&#9;</run>
                <run bold='true'><![CDATA[<[federated.06mgibo0zdgdib1bhxrjp1fyqgp5].[none:seller_id:nk]>]]></run>
