            <groupfilter function='union' user:op='manual'>
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.06mgibo0zdgdib1bhxrjp1fyqgp5].[sum:total_negative_reviews:qk]&quot;' />
