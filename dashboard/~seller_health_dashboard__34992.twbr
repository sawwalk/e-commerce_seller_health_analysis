    <dashboard enable-sort-zone-taborder='true' name='Platform Health Overview'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontname='Tableau Medium' fontsize='24'>&lt;Sheet Name&gt;</run>
          </formatted-text>
